{
  "bank_statement": {
    "account_holder_name": {
      "keywords": ["ENCIK", "PUAN", "account holder", "name", "nama", "account name"],
      "pattern": null,
      "required": true,
      "fallback_patterns": [
        "(?:ENCIK|PUAN|Name|Nama|Account Holder|Pemegang Akaun|Account Name)[:\\s]*([A-Z][A-Z\\s]+)",
        "^([A-Z][A-Z\\s]{10,})$"
      ],
      "exclusion_patterns": [
        "Statement", "Penyata", "Account", "Akaun", "Bank", "Address", "Alamat", "Date", "Tarikh", "BRANCH", "CAWANGAN"
      ]
    },
    "account_number": {
      "keywords": ["ACCOUNT NO", "NO AKAUN", "account number", "account no", "akaun", "no akaun", "ACC NO", "A/C NO"],
      "pattern": "\\d{10,}",
      "required": true,
      "fallback_patterns": [
        "(?:ACCOUNT NO|Account Number|NO AKAUN|No Akaun|Akaun|ACC NO|A/C NO)[:\\s]*(?:NO)?[:\\s]*(\\d{2,}-\\d{7,}-\\d{1,})",
        "(?:ACCOUNT NO|Account Number|NO AKAUN|No Akaun|Akaun|ACC NO|A/C NO)[:\\s]*(?:NO)?[:\\s]*(\\d{10,})",
        "(?:A/C|ACC)[:\\s]*(\\d{10,})",
        "\\b(\\d{11,14})\\b"
      ]
    },
    "statement_date": {
      "keywords": ["STATEMENT DATE", "TARIKH PENYATA", "date", "statement date", "tarikh penyata", "tarikh", "period"],
      "pattern": "\\d{2}/\\d{2}/\\d{2,4}",
      "required": true,
      "fallback_patterns": [
        "(?:STATEMENT DATE|Statement Date|Date|Tarikh|TARIKH PENYATA|Tarikh Penyata|Statement Date|Period)[:\\s]*(\\d{2}/\\d{2}/\\d{2,4})",
        "(?:From|Dari)[:\\s]*(\\d{2}/\\d{2}/\\d{2,4})",
        "\\b(\\d{2}/\\d{2}/\\d{2,4})\\b"
      ]
    },
    "opening_balance": {
      "keywords": ["opening", "opening balance", "beginning balance", "baki awal", "BAKI AWAL", "baki hadapan", "BAKI HADAPAN", "BAL B/F", "BAKI B/F"],
      "pattern": "[\\d,]+\\.\\d{2}",
      "required": true,
      "fallback_patterns": [
        "(?:Opening Balance|OPENING BALANCE|Baki Awal|BAKI AWAL|Baki Hadapan|BAKI HADAPAN|Beginning Balance|Baki Permulaan|Balance B/F|BAL B/F|BAKI B/F)[:\\s]*(?:RM)?[:\\s]*([\\d,]+\\.?\\d*)"
      ],
      "exclusion_keywords": ["peratus", "rate", "kadar", "%", "percent"]
    },
    "closing_balance": {
      "keywords": ["closing", "closing balance", "ending balance", "balance", "baki akhir", "baki penutup", "BAKI AKHIR", "BAKI PENUTUP", "BALANCE", "BAL C/F", "BAKI C/F"],
      "pattern": "[\\d,]+\\.\\d{2}",
      "required": true,
      "fallback_patterns": [
        "(?:Closing Balance|CLOSING BALANCE|Baki Akhir|BAKI AKHIR|Baki Penutup|BAKI PENUTUP|Ending Balance|Balance|Baki Penutup|Balance C/F|BAL C/F|BAKI C/F)[:\\s]*(?:RM)?[:\\s]*([\\d,]+\\.?\\d*)",
        "(?:Current Balance|Baki Semasa|CURRENT BALANCE|Baki Terkini)[:\\s]*(?:RM)?[:\\s]*([\\d,]+\\.?\\d*)"
      ],
      "exclusion_keywords": ["peratus", "rate", "kadar", "%", "percent", "available", "tersedia"]
    },
    "total_debit": {
      "keywords": ["total debit", "total debits", "jumlah debit", "TOTAL DEBIT", "JUMLAH DEBIT", "debit"],
      "pattern": "[\\d,]+\\.\\d{2}",
      "required": false,
      "fallback_patterns": [
        "(?:Total Debit|TOTAL DEBIT|Jumlah Debit|JUMLAH DEBIT)[:\\s]*(?:RM)?[:\\s]*([\\d,]+\\.?\\d*)",
        "(?:Total Withdrawal|TOTAL WITHDRAWAL|Jumlah Pengeluaran|JUMLAH PENGELUARAN)[:\\s]*(?:RM)?[:\\s]*([\\d,]+\\.?\\d*)"
      ]
    },
    "total_credit": {
      "keywords": ["total credit", "total credits", "jumlah kredit", "TOTAL CREDIT", "JUMLAH KREDIT", "credit"],
      "pattern": "[\\d,]+\\.\\d{2}",
      "required": false,
      "fallback_patterns": [
        "(?:Total Credit|TOTAL CREDIT|Jumlah Kredit|JUMLAH KREDIT)[:\\s]*(?:RM)?[:\\s]*([\\d,]+\\.?\\d*)",
        "(?:Total Deposit|TOTAL DEPOSIT|Jumlah Deposit|JUMLAH DEPOSIT)[:\\s]*(?:RM)?[:\\s]*([\\d,]+\\.?\\d*)"
      ]
    },
    "statement_period_from": {
      "keywords": ["from", "dari", "period from", "statement from", "tempoh dari"],
      "pattern": "\\d{2}/\\d{2}/\\d{2,4}",
      "required": false,
      "fallback_patterns": [
        "(?:From|Dari|Period From|Tempoh Dari)[:\\s]*(\\d{2}/\\d{2}/\\d{2,4})"
      ]
    },
    "statement_period_to": {
      "keywords": ["to", "hingga", "period to", "statement to", "tempoh hingga", "sehingga"],
      "pattern": "\\d{2}/\\d{2}/\\d{2,4}",
      "required": false,
      "fallback_patterns": [
        "(?:To|Hingga|Period To|Tempoh Hingga|Sehingga)[:\\s]*(\\d{2}/\\d{2}/\\d{2,4})"
      ]
    }
  }
}
